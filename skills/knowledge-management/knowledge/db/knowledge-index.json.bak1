      "quality": 87,
      "quality_computed": 87,
      "success_rate": null,
      "learned_date": "2026-04-13"
    },
    "km_c1326e2c7008": {
      "id": "km_c1326e2c7008",
      "title": "国家发改委数据要素3年计划:增速超20%,科学数据支持大模型开发算法人工智能技术",
